{
  "expo": {
    "name": "BhcJobs",
    "slug": "BhcJobs",
    "version": "1.0.0",
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "experiments": {
      "tsconfigPaths": true
    },
    "plugins": [
      "@react-native-community/datetimepicker"
    ],
    "orientation": "portrait",
    "icon": "./assets/bhcjobs_logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shuvajitmaitra.BhcJobs"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/bhcjobs_logo.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.shuvajitmaitra.BhcJobs"
    }
  }
}
